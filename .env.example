# ============================================================
# AutoTreehole 环境变量示例
# 复制为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会提交）
# ============================================================

# ---- 树洞 API 凭证（爬虫 + 图片代理必需）----
# 登录 https://treehole.pku.edu.cn 后，F12 取：
#   Application → Cookies → pku_token
PKU_TOKEN=
#   Network → 任一请求头 → uuid
PKU_UUID=

# ---- 数据库路径（默认 ./treehole.db）----
TREEHOLE_DB_PATH=./treehole.db

# ---- 访问令牌签名密钥（随机长字符串，务必自行修改）----
TOKEN_SECRET=please_change_me_to_a_random_long_string

# ---- 数据后台管理密码（admin.html 登录用）----
ADMIN_PASSWORD=please_change_me

# ---- 邮件服务（QQ 邮箱 SMTP，用于邮箱验证码 + 站长信箱转发）----
# MAIL_USER：发件邮箱地址
MAIL_USER=
# MAIL_PASS：邮箱 SMTP 授权码（非登录密码），在邮箱设置中开启 SMTP 后获取
MAIL_PASS=

# ---- 站长邮箱（接收用户留言，不会暴露给前端）----
SITE_OWNER_EMAIL=

# ---- 站点公开地址（用于邮件内链接与 Agent 配置片段，如 https://your-domain.com）----
# 关键词订阅推送邮件的"前往网站/一键退订"链接会用到；
# Agent Token 创建时返回的 MCP 配置片段中的 AUTOTREEHOLE_URL 也取自这里
# 留空则邮件内不生成可点击链接，且 Agent 功能不可用
PUBLIC_BASE_URL=

# ---- MiniMax（LLM 分类 / 默认 AI 报告，可选）----
# 服务器持有的默认公共模型 Key；其他模型由用户浏览器直连调用
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3

# ---- 通义千问 Qwen（MiniMax 限额时的备用公共模型，可选）----
# 服务器持有的第二公共模型 Key；MiniMax 调用失败时自动 fallback 到 Qwen
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-flash
